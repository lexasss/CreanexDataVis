<Window x:Class="CreanexDataVis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreanexDataVis"
        mc:Ignorable="d"
        Title="Creanex Data Visualization"
        Icon="/Assets/Images/icon.png"
        Height="292"
        Width="1200"
        MinHeight="292"
        MaxHeight="292"
        MinWidth="400"
        PreviewMouseDoubleClick="Window_PreviewMouseDoubleClick">
    <Grid>
        <Label x:Name="lblPrompt"
               Content="Double-click to load data"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               FontSize="16"
               Foreground="Gray"/>
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      VerticalAlignment="Top">
            <Image x:Name="TimelineImage"/>
        </ScrollViewer>
        <StackPanel>
            <StackPanel.Resources>
                <Style TargetType="Label">
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Margin" Value="2"/>
                </Style>
            </StackPanel.Resources>
            <Label>Harvester events</Label>
            <Label>Left Window</Label>
            <Label>Front Window</Label>
            <Label>Right Window</Label>
            <Label>TDA Screen</Label>
            <Label>Harvester Head</Label>
            <Label>Target Tree</Label>
        </StackPanel>
    </Grid>
</Window>
