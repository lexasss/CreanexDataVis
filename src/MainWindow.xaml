<Window x:Class="CreanexDataVis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreanexDataVis"
        mc:Ignorable="d"
        Title="Creanex Data Visualization"
        Icon="/Assets/Images/icon.png"
        Height="322"
        Width="1200"
        MinHeight="322"
        MinWidth="400">
    <TabControl>
        <TabItem Header="Gazing timeline">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ToolBar Grid.Row="0">
                    <Button Content="Load..." Click="LoadGazingTimeline_Click"/>
                </ToolBar>
                <ScrollViewer x:Name="scvTimeline"
                      Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      VerticalAlignment="Top">
                    <!--Image x:Name="imgTimeline"/-->
                </ScrollViewer>
                <StackPanel Grid.Row="1">
                    <StackPanel.Resources>
                        <Style TargetType="Label">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Margin" Value="2"/>
                        </Style>
                    </StackPanel.Resources>
                    <Label>Harvester events</Label>
                    <Label>Left Window</Label>
                    <Label>Front Window</Label>
                    <Label>Right Window</Label>
                    <Label>TDA Screen</Label>
                    <Label>Harvester Head</Label>
                    <Label>Target Tree</Label>
                </StackPanel>
            </Grid>
        </TabItem>
        <TabItem Header="Gaze point">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ToolBar Grid.Row="0">
                    <Button Content="Load..." Click="LoadGazePoint_Click"/>
                </ToolBar>
                <ScrollViewer x:Name="scvGazePoints"
                      Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      VerticalAlignment="Top">
                </ScrollViewer>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
