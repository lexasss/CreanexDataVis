<Window x:Class="CreanexDataVis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreanexDataVis"
        xmlns:hlp="clr-namespace:CreanexDataVis.Helpers"
        xmlns:conv="clr-namespace:CreanexDataVis.Converters"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        mc:Ignorable="d"
        Title="Creanex Data Visualization"
        Icon="/Assets/Images/icon.png"
        Height="722"
        Width="1200"
        MinHeight="620"
        MinWidth="496"
        PreviewKeyDown="Window_PreviewKeyDown">
    
    <Window.InputBindings>
        <KeyBinding 
            Key="Space" 
            Command="{Binding TogglePlayVideoCommand}" />
    </Window.InputBindings>
    
    <Window.Resources>
        <conv:NegateConveter x:Key="Not"/>

        <Style x:Key="ToolbarIconButton" TargetType="Button">
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <ToolBarTray Grid.Row="0">
            <ToolBar>
                <Label Content="Timeline:"/>
                <Button Style="{StaticResource ToolbarIconButton}"
                        Content="📂"
                        Command="{Binding LoadCreanexDataCommand}"
                        IsEnabled="{Binding IsPlaying, Converter={StaticResource Not}}"/>
            </ToolBar>
            
            <ToolBar>
                <Label Content="Video:"/>
                <Button Style="{StaticResource ToolbarIconButton}"
                        Content="📂"
                        Command="{Binding LoadVideoCommand}"
                        IsEnabled="{Binding IsPlaying, Converter={StaticResource Not}}"/>
                <Label Content="Delaying"/>
                <TextBox Width="40"
                         Text="{Binding VideoDelay, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="seconds"/>
                <Separator/>
                <Button Style="{StaticResource ToolbarIconButton}"
                        Content="{Binding TogglePlayVideoCommandLabel}"
                        Command="{Binding TogglePlayVideoCommand}"
                        IsEnabled="{Binding IsPlaybackEnabled}"/>
            </ToolBar>

            <ToolBar>
                <Label Content="Varjo:"/>
                <Button Style="{StaticResource ToolbarIconButton}"
                            Content="📂"
                            Command="{Binding LoadVarjoDataCommand}"
                            IsEnabled="{Binding IsPlaying, Converter={StaticResource Not}}"/>
            </ToolBar>
        </ToolBarTray>

        <ScrollViewer Grid.Row="1"
                        Content="{Binding Timeline}"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        VerticalAlignment="Top"
                        hlp:ScrollViewerProperties.HorizontalOffset="{Binding TimelineScrollX, Mode=TwoWay}"
                        hlp:ScrollViewerProperties.BindableViewportWidth="{Binding TimelineWidth, Mode=OneWayToSource}"
                        hlp:ScrollViewerProperties.EnableExtraBindings="True">
            <!--Image x:Name="imgTimeline"/-->
        </ScrollViewer>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Left">
            <StackPanel.Resources>
                <Style TargetType="Label">
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Margin" Value="2"/>
                    <Setter Property="Background" Value="#99FFFFFF"/>
                </Style>
            </StackPanel.Resources>
            <Label Content="Driving / grabbing"></Label>
            <Label>Left Window</Label>
            <Label>Front Window</Label>
            <Label>Right Window</Label>
            <Label>TDA Screen</Label>
            <Label>Harvester Head</Label>
            <Label>Tree (+ID)</Label>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <MediaElement x:Name="VideoPlayer" Grid.Column="0"
                        MinWidth="480"
                        MinHeight="320"
                        Stretch="Uniform"
                        LoadedBehavior="Manual"
                        UnloadedBehavior="Manual"/>
            
            <ScrollViewer Grid.Column="1"
                        Content="{Binding GazePlot}"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        VerticalAlignment="Top"/>

            <ScrollViewer Grid.Column="2">
                <hx:Viewport3DX EffectsManager="{Binding GazePlotEffectsManager}" 
                                ShowCoordinateSystem="True"
                                ShowViewCube="False"
                                CoordinateSystemHorizontalPosition="0.8">
                    <hx:Viewport3DX.Camera>
                        <hx:PerspectiveCamera Position="2,0,0"
                                              LookDirection="-2,0,0"
                                              UpDirection="0,1,0"/>
                    </hx:Viewport3DX.Camera>
                    <hx:DirectionalLight3D Direction="-1,0,0" Color="White"/>
                    <hx:AmbientLight3D Color="Red" />
                    
                    <hx:LineGeometryModel3D FixedSize="True"
                                    Geometry="{Binding GazePlot3D}"
                                    IsRendering="True"
                                    Smoothness="2.0"
                                    Thickness="0.5"
                                    Color="Yellow" />
                    <hx:MeshGeometryModel3D 
                        Geometry="{Binding GazePlot3DHead}"
                        Material="{Binding GazePlot3DHeadMaterial}"
                        Transform="{Binding GazePlot3DHeadTransform}">
                    </hx:MeshGeometryModel3D>
                </hx:Viewport3DX>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
