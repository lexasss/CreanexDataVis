<Window x:Class="CreanexDataVis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreanexDataVis"
        xmlns:hlp="clr-namespace:CreanexDataVis.Helpers"
        xmlns:conv="clr-namespace:CreanexDataVis.Converters"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Icon="/Assets/Images/icon.png"
        Height="722"
        Width="1200"
        MinHeight="620"
        MinWidth="496">
    <Window.Resources>
        <Style x:Key="ToolbarIconButton" TargetType="Button">
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <conv:NegateConveter x:Key="Not"/>
    </Window.Resources>
    
    <TabControl>
        <TabItem Header="Gazing timeline">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ToolBarTray Grid.Row="0">
                    <ToolBar>
                        <Label Content="Data:"/>
                        <Button Style="{StaticResource ToolbarIconButton}"
                                Content="📂"
                                Command="{Binding LoadCreanexDataCommand}"
                                IsEnabled="{Binding IsPlaying, Converter={StaticResource Not}}"/>
                    </ToolBar>
                    <ToolBar>
                        <Label Content="Video:"/>
                        <Button Style="{StaticResource ToolbarIconButton}"
                                Content="📂"
                                Command="{Binding LoadVideoCommand}"
                                IsEnabled="{Binding IsPlaying, Converter={StaticResource Not}}"/>
                        <Label Content="Delaying"/>
                        <TextBox Width="40" Text="{Binding VideoDelay}"/>
                        <Label Content="seconds"/>
                        <Separator/>
                        <Button Style="{StaticResource ToolbarIconButton}"
                                Content="{Binding PlayVideoCommandLabel}"
                                Command="{Binding PlayVideoCommand}"
                                IsEnabled="{Binding IsPlaybackEnabled}"/>
                    </ToolBar>
                </ToolBarTray>

                <ScrollViewer Grid.Row="1"
                              Content="{Binding Timeline}"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              VerticalAlignment="Top"
                              hlp:ScrollViewerBinding.HorizontalOffset="{Binding TimelineScrollX, Mode=TwoWay}"
                              hlp:ScrollViewerBinding.BindableViewportWidth="{Binding TimelineWidth, Mode=OneWayToSource}"
                              hlp:ScrollViewerBinding.EnableViewportWidthBinding="True">
                    <!--Image x:Name="imgTimeline"/-->
                </ScrollViewer>
                <StackPanel Grid.Row="1">
                    <StackPanel.Resources>
                        <Style TargetType="Label">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Margin" Value="2"/>
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                        </Style>
                    </StackPanel.Resources>
                    <Label>Harvester events</Label>
                    <Label>Left Window</Label>
                    <Label>Front Window</Label>
                    <Label>Right Window</Label>
                    <Label>TDA Screen</Label>
                    <Label>Harvester Head</Label>
                    <Label>Target Tree</Label>
                </StackPanel>

                <MediaElement x:Name="VideoPlayer" Grid.Row="2"
                              MinWidth="480"
                              MinHeight="320"
                              Stretch="Uniform"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop"/>
            </Grid>
        </TabItem>
        <TabItem Header="Gaze point">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ToolBar Grid.Row="0">
                    <Label Content="Data:"/>
                    <Button Style="{StaticResource ToolbarIconButton}"
                            Content="📂"
                            Command="{Binding LoadVarjoDataCommand}"
                            IsEnabled="{Binding IsPlaying, Converter={StaticResource Not}}"/>
                </ToolBar>
                <ScrollViewer Grid.Row="1"
                              Content="{Binding GazePlot}"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              VerticalAlignment="Top">
                </ScrollViewer>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
