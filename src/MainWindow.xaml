<Window x:Class="CreanexDataVis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreanexDataVis"
        xmlns:srv="clr-namespace:CreanexDataVis.Services"
        xmlns:vm="clr-namespace:CreanexDataVis.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Icon="/Assets/Images/icon.png"
        Height="722"
        Width="1200"
        MinHeight="322"
        MinWidth="400">

    <TabControl>
        <TabItem Header="Gazing timeline">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ToolBarTray Grid.Row="0">
                    <ToolBar>
                        <Label Content="Data:"/>
                        <Button Content="📂" Command="{Binding LoadCreanexDataCommand}"/>
                    </ToolBar>
                    <ToolBar>
                        <Label Content="Video:"/>
                        <Button Content="📂" Command="{Binding LoadVideoCommand}"/>
                        <Label Content="Delaying"/>
                        <TextBox Width="40" Text="{Binding VideoDelay}"/>
                        <Label Content="seconds"/>
                        <Separator/>
                        <Button Content="{Binding PlayVideoCommandLabel}"
                                Command="{Binding PlayVideoCommand}"
                                IsEnabled="{Binding IsPlaybackEnabled}"/>
                    </ToolBar>
                </ToolBarTray>

                <ScrollViewer Grid.Row="1"
                              Content="{Binding Timeline}"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              VerticalAlignment="Top"
                              srv:ScrollViewerBinding.HorizontalOffset="{Binding TimelineScrollX, Mode=TwoWay}"
                              srv:ScrollViewerBinding.BindableViewportWidth="{Binding TimelineWidth, Mode=OneWayToSource}"
                              srv:ScrollViewerBinding.EnableViewportWidthBinding="True">
                    <!--Image x:Name="imgTimeline"/-->
                </ScrollViewer>
                <StackPanel Grid.Row="1">
                    <StackPanel.Resources>
                        <Style TargetType="Label">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Margin" Value="2"/>
                        </Style>
                    </StackPanel.Resources>
                    <Label>Harvester events</Label>
                    <Label>Left Window</Label>
                    <Label>Front Window</Label>
                    <Label>Right Window</Label>
                    <Label>TDA Screen</Label>
                    <Label>Harvester Head</Label>
                    <Label>Target Tree</Label>
                </StackPanel>

                <MediaElement x:Name="VideoPlayer" Grid.Row="2"
                              Source="{Binding VideoSource}"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop"/>
            </Grid>
        </TabItem>
        <TabItem Header="Gaze point">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ToolBar Grid.Row="0">
                    <Label Content="Data:"/>
                    <Button Content="📂" Command="{Binding LoadVarjoDataCommand}"/>
                </ToolBar>
                <ScrollViewer Grid.Row="1"
                              Content="{Binding GazePlot}"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              VerticalAlignment="Top">
                </ScrollViewer>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
